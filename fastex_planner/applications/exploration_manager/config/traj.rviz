Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /LocalMap1
        - /LocalMap1/local_map1/Autocompute Value Bounds1
        - /Planning1
        - /Mapping1
        - /Mapping1/simulation_map1/Autocompute Value Bounds1
      Splitter Ratio: 0.5
    Tree Height: 712
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.588679016
  - Class: rviz/Views
    Expanded:
      - /Current View1
      - /ThirdPersonFollower1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: ""
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz/Axes
      Enabled: false
      Length: 10
      Name: Axes
      Radius: 0.100000001
      Reference Frame: <Fixed Frame>
      Value: false
    - Alpha: 0.5
